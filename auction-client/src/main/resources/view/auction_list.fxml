<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.client.controller.AuctionListController"
      prefHeight="700.0" prefWidth="900.0"
      styleClass="main-bg">

    <!-- Navbar -->
    <HBox alignment="CENTER_LEFT" spacing="20" styleClass="bg-white" style="-fx-padding: 15 30; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
        <Label text="BidVault" styleClass="text-2xl, font-bold, text-foreground"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="userInfoLabel" styleClass="text-sm, text-muted, font-bold"/>
        <Button text="Đăng xuất" onAction="#handleLogout" styleClass="btn-outline"/>
    </HBox>

    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
        <VBox spacing="25" alignment="TOP_CENTER" style="-fx-padding: 30;">
            
            <!-- Hero / Title -->
            <VBox alignment="CENTER" spacing="10" styleClass="card" style="-fx-background-color: linear-gradient(to bottom right, #1e293b, #334155); -fx-padding: 40;">
                <Label text="Đấu giá trực tuyến chuyên nghiệp." styleClass="text-white, text-3xl, font-bold"/>
                <Label text="Khám phá các phiên đấu giá đang diễn ra và đặt giá cho sản phẩm bạn yêu thích." styleClass="text-muted, text-sm"/>
                <Button text="Tải lại danh sách" onAction="#handleRefresh" styleClass="btn-gold">
                    <VBox.margin><Insets top="15"/></VBox.margin>
                </Button>
            </VBox>

            <!-- Main Content -->
            <VBox spacing="15" styleClass="card" VBox.vgrow="ALWAYS" maxWidth="800">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Phiên nổi bật" styleClass="text-xl, font-bold, text-foreground"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="statusLabel" styleClass="text-sm, text-danger"/>
                </HBox>
                
                <ListView fx:id="listView" styleClass="list-view" VBox.vgrow="ALWAYS" prefHeight="400"/>
            </VBox>

        </VBox>
    </ScrollPane>

</VBox>