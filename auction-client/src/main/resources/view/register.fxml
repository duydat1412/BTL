<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.auction.client.controller.RegisterController"
            prefHeight="400" prefWidth="600">

    <children>

        <Label text="Register" layoutX="250" layoutY="60"/>

        <TextField fx:id="usernameField"
                   promptText="Username"
                   layoutX="200" layoutY="110"/>

        <PasswordField fx:id="passwordField"
                       promptText="Password"
                       layoutX="200" layoutY="150"/>

        <TextField fx:id="emailField"
                   promptText="Email"
                   layoutX="200" layoutY="190"/>

        <ComboBox fx:id="roleBox"
                  layoutX="200" layoutY="230"
                  prefWidth="150"
                  promptText="Chọn vai trò"/>

        <Button text="Register"
                layoutX="200" layoutY="270"
                onAction="#handleRegister"/>

        <Button text="Back"
                layoutX="300" layoutY="270"
                onAction="#goBack"/>

        <Label fx:id="messageLabel"
               layoutX="200" layoutY="310"/>

    </children>
</AnchorPane>