<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.client.controller.RegisterController"
      prefHeight="600.0" prefWidth="900.0"
      styleClass="main-bg">

    <!-- Trái: Phần giới thiệu -->
    <VBox HBox.hgrow="ALWAYS" styleClass="gradient-primary" alignment="CENTER_LEFT">
        <padding><Insets top="40" bottom="40" left="40" right="40"/></padding>
        <Label text="BidVault" styleClass="text-white, text-lg, font-bold"/>
        <Region VBox.vgrow="ALWAYS"/>
        <Label text="Tạo tài khoản mới&#10;Tham gia ngay!" styleClass="text-white, text-3xl, font-bold" wrapText="true"/>
        <Label text="Mở ra thế giới đấu giá trực tuyến. Trở thành người mua để săn hàng độc, hoặc người bán để tối đa lợi nhuận." styleClass="text-muted, text-sm" wrapText="true" maxWidth="350">
            <VBox.margin><Insets top="10"/></VBox.margin>
        </Label>
        <Region VBox.vgrow="ALWAYS"/>
        <Label text="© BidVault 2025" styleClass="text-muted, text-xs"/>
    </VBox>

    <!-- Phải: Form đăng ký -->
    <StackPane prefWidth="450" styleClass="bg-white">
        <VBox alignment="CENTER_LEFT" spacing="15" maxWidth="350">
            
            <VBox spacing="2">
                <Label text="Tạo tài khoản" styleClass="text-2xl, font-bold, text-foreground"/>
                <Label text="Vui lòng điền thông tin để tiếp tục" styleClass="text-sm, text-muted"/>
            </VBox>
            
            <VBox spacing="5">
                <Label text="Tên đăng nhập" styleClass="text-sm, font-bold, text-foreground"/>
                <TextField fx:id="usernameField" promptText="Nhập tên đăng nhập" styleClass="input-field"/>
            </VBox>
            
            <VBox spacing="5">
                <Label text="Mật khẩu" styleClass="text-sm, font-bold, text-foreground"/>
                <PasswordField fx:id="passwordField" promptText="VD: Abc@1234" styleClass="input-field"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Email" styleClass="text-sm, font-bold, text-foreground"/>
                <TextField fx:id="emailField" promptText="you@example.com" styleClass="input-field"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Vai trò" styleClass="text-sm, font-bold, text-foreground"/>
                <ComboBox fx:id="roleBox" promptText="Chọn vai trò" styleClass="combo-box" maxWidth="Infinity"/>
            </VBox>

            <Button text="Đăng ký tài khoản" onAction="#handleRegister" styleClass="btn-gold" maxWidth="Infinity">
                <VBox.margin><Insets top="5"/></VBox.margin>
            </Button>
            
            <Button text="Quay lại Đăng nhập" onAction="#goBack" styleClass="btn-outline" maxWidth="Infinity"/>
            
            <Label fx:id="messageLabel" styleClass="text-danger, text-sm" wrapText="true" alignment="CENTER" maxWidth="Infinity"/>
        </VBox>
    </StackPane>

</HBox>